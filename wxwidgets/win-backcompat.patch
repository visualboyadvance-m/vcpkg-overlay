+HRESULT
+wxDrawThemeTextEx(HTHEME hTheme, HDC hdc, int iPartId, int iStateId,
+                  const wchar_t* pszText, int cchText, DWORD dwTextFlags,
+                  RECT* pRect, const DTTOPTS* pOptions)
+{
+    // DrawThemeTextEx() is not available under XP and can't even be imported
+    // statically there without preventing the application from loading, so
+    // resolve it dynamically on first use.
+    typedef HRESULT (WINAPI *DrawThemeTextEx_t)(HTHEME, HDC, int, int, LPCWSTR,
+                                                int, DWORD, LPRECT,
+                                                const DTTOPTS*);
+    static DrawThemeTextEx_t s_pfnDrawThemeTextEx = nullptr;
+    static bool s_initDone = false;
+
+    if ( !s_initDone )
+    {
+        wxLoadedDLL dllUxTheme(wxS("uxtheme.dll"));
+        wxDL_INIT_FUNC(s_pfn, DrawThemeTextEx, dllUxTheme);
+        s_initDone = true;
+    }
+
+    if ( s_pfnDrawThemeTextEx )
+    {
+        return s_pfnDrawThemeTextEx(hTheme, hdc, iPartId, iStateId, pszText,
+                                    cchText, dwTextFlags, pRect, pOptions);
+    }
+
+    // Fall back to DrawThemeText() under XP, losing the extended options.
+    return ::DrawThemeText(hTheme, hdc, iPartId, iStateId, pszText, cchText,
+                           dwTextFlags, 0, pRect);
+}
