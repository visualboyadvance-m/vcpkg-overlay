+// ----------------------------------------------------------------------------
+// wxKernel32Dll: access to kernel32 NLS functions not available under XP
+// ----------------------------------------------------------------------------
+
+// Several NLS functions taking locale names (rather than the legacy LCIDs)
+// only appeared in Vista, and a couple of others only in Windows 7. Rather
+// than reloading kernel32.dll and re-resolving the symbols at every call, we
+// resolve them once here and let the code below check each pointer for null
+// and fall back to the legacy LCID-based functions when running under XP.
+class wxKernel32Dll
+{
+public:
+    // Return the unique instance, resolving the functions on first use.
+    static const wxKernel32Dll& Get()
+    {
+        static const wxKernel32Dll s_instance;
+        return s_instance;
+    }
+
+    typedef int  (WINAPI *GetLocaleInfoEx_t)(LPCWSTR, LCTYPE, LPWSTR, int);
+    typedef int  (WINAPI *GetUserDefaultLocaleName_t)(LPWSTR, int);
+    typedef BOOL (WINAPI *GetUserPreferredUILanguages_t)(DWORD, PULONG,
+                                                         PZZWSTR, PULONG);
+    typedef BOOL (WINAPI *SetThreadPreferredUILanguages_t)(DWORD, PCZZWSTR,
+                                                           PULONG);
+    typedef int  (WINAPI *CompareStringEx_t)(LPCWSTR, DWORD, LPCWCH, int,
+                                             LPCWCH, int, LPNLSVERSIONINFO,
+                                             LPVOID, LPARAM);
+
+    // Any of these is null if the corresponding function is not available in
+    // the current system and so must be checked before being called.
+    GetLocaleInfoEx_t               GetLocaleInfoEx;
+    GetUserDefaultLocaleName_t      GetUserDefaultLocaleName;
+    GetUserPreferredUILanguages_t   GetUserPreferredUILanguages;
+    SetThreadPreferredUILanguages_t SetThreadPreferredUILanguages;
+    CompareStringEx_t               CompareStringEx;
+
+private:
+    wxKernel32Dll()
+    {
+        // kernel32.dll is always already loaded, so this can't realistically
+        // fail, but use wxDL_QUIET just in case to avoid spurious errors.
+        m_dll.Load(wxS("kernel32.dll"), wxDL_VERBATIM | wxDL_QUIET);
+
+        GetLocaleInfoEx = (GetLocaleInfoEx_t)
+            m_dll.RawGetSymbol("GetLocaleInfoEx");
+        GetUserDefaultLocaleName = (GetUserDefaultLocaleName_t)
+            m_dll.RawGetSymbol("GetUserDefaultLocaleName");
+        GetUserPreferredUILanguages = (GetUserPreferredUILanguages_t)
+            m_dll.RawGetSymbol("GetUserPreferredUILanguages");
+        SetThreadPreferredUILanguages = (SetThreadPreferredUILanguages_t)
+            m_dll.RawGetSymbol("SetThreadPreferredUILanguages");
+        CompareStringEx = (CompareStringEx_t)
+            m_dll.RawGetSymbol("CompareStringEx");
+    }
+
+    wxDynamicLibrary m_dll;
+
+    wxDECLARE_NO_COPY_CLASS(wxKernel32Dll);
+};
+
 } // anonymous namespace
 
